# AWS Configuration
# Copy this file to .env.local and fill in your AWS credentials

# AWS Region
AWS_REGION=us-east-1

# AWS Access Key ID
AWS_ACCESS_KEY_ID=your-access-key-id

# AWS Secret Access Key
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# S3 Bucket Name
AWS_S3_BUCKET_NAME=your-bucket-name

# Note: Ensure your IAM user has permissions for:
# - S3 (PutObject, GetObject)
# - Rekognition (DetectLabels)
# - Bedrock (InvokeModel for Titan Image Generator v2, Claude 3 Haiku)
